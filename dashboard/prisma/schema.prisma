generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Destination {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
