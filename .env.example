# =============================================================
#  InoveMakeBot - Template de Variáveis de Ambiente
#  Copie para .env e preencha com seus valores reais
# =============================================================

# ── Banco de Dados (PostgreSQL) ──────────────────────────────
DB_USER=inove_user
DB_PASSWORD=TROQUE_POR_SENHA_FORTE
DB_NAME=inove_db
EVOLUTION_DB_NAME=evolution_db

# ── Evolution API ────────────────────────────────────────────
# Gere com: uuidgen ou https://www.uuidgenerator.net/
EVOLUTION_API_KEY=SEU-UUID-AQUI
# IP ou domínio público da máquina
SERVER_URL=http://SEU_IP:8080
# URL interna (comunicação entre containers)
EVOLUTION_INTERNAL_URL=http://inove_evolution:8080

# ── n8n ──────────────────────────────────────────────────────
N8N_HOST=SEU_IP
N8N_PORT=5678
N8N_WEBHOOK_URL=http://SEU_IP:5678
# Nome da instância WhatsApp criada na Evolution API
INSTANCE_NAME=inove-bot
INSTANCE_DESCRIPTION=InoveMakeBot v1

# ── Dashboard (Next.js) ──────────────────────────────────────
# Gere com: openssl rand -hex 32
NEXTAUTH_SECRET=GERE_COM_openssl_rand_hex_32
# URL do dashboard acessível pelo n8n (interno)
NEXT_PUBLIC_API_URL=http://inove_dashboard:3000

# ── Segurança n8n ─────────────────────────────────────────────
N8N_SECURE_COOKIE=false
